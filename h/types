#ifndef TYPES_H
#define TYPES_H

#include <stdint.h>
#include <stdbool.h>


/* Constants */

/* .Bits */
#define Error_MessageTransTokenNotFound          ((uint32_t)0xac2)
#define Error_MessageTransFileOpen               ((uint32_t)0xac1)
#define Error_MessageTransSyntax                 ((uint32_t)0xac0)
#define Error_MessageTransRecurse                ((uint32_t)0xac3)

/* MessageTrans_FileFlags */
#define MessageTrans_DirectAccess                ((MessageTrans_FileFlags)(1<<0))



/* Types */

typedef struct MessageTrans_ControlBlock {
    uint32_t magic;
    uint32_t size;
    void *   messagefile;   /* 4 bytes on RISC OS 32; 8 bytes on RISC OS 64 */
#ifndef __riscos64
    uint32_t UNUSED;        /* Only available on RISC OS 32 */
#endif
} MessageTrans_ControlBlock;

typedef uint32_t MessageTrans_FileFlags;


#endif

#include "wildcard.h"

/*************************************************** Gerph *********
 Function:     wildmatch_mt
 Description:  Check whether we match a wildcard (case sensitive,
               for messagetrans)
 Parameters:   wild-> the wildcard to match with, terminated by
                      0, 10, 13, ':'
               str-> the string to match, terminated by
                     0, 10, 13, ':', '/'
               end-> where to stop matching
 Returns:      1 if matched, 0 if no match
 ******************************************************************/
int wildmatch_mt(const char *wild, const char *str, const char *end)
{
    do
    {
        char w = *wild;
        char s = *str;

        if (str >= end)
            return 0; /* Didn't match if we got to here */

        if (w == '\r' || w == '\n' || w == ':')
            w = '\0';
        if (s == '\r' || s == '\n' || s == ':' || s == '/')
            s = '\0';

        if (s == '\0')
        {
            if (w == '*')
            {
                wild++;
                continue;
            }
            if (w == '\0')
                return 1;       /* Equal */
        }

        if (w == '\0')
            return 0;           /* Not equal */

        if (s != '*')
        {
            if (w == s || w == '?')
            {
                wild++;
                str++;
                continue;
            }
        }
        if (w != '*')
            return 0;           /* Not equal */

        if (wildmatch_mt(wild + 1, str, end))
            return 1;
        return wildmatch_mt(wild, str + 1, end);
    } while (1);
}


#ifdef TEST_WILDCARD

#include <string.h>
#include <stdio.h>

int pass = 0;
int fail = 0;

void wildtest(const char *str, const char *end, const char *wild, int match)
{
    int gave;
    printf("Test '%s' : '%s' : ", str, wild);
    gave = wildmatch_mt(wild, str, end);
    printf("%i/%i%s\n", gave, match, gave == match ? "" : "   **FAIL**");
    if (gave == match)
        pass++;
    else
        fail++;
}

int main(void)
{
    const char *teststring = "The quick brown fox.* The candlestick";
    const char *end = teststring + strlen(teststring) + 1;
    wildtest(teststring, end, "The*", 1);
    wildtest(teststring, end, "*he*", 1);
    wildtest(teststring, end, "*ck", 1);
    wildtest(teststring, end, "*heck", 0);
    wildtest(teststring, end, "* The*", 1);
    wildtest(teststring, end, "*The*", 1);
    wildtest(teststring, end, "and", 0);
    wildtest(teststring, end, "*and", 0);
    wildtest(teststring, end, "and*", 0);
    wildtest(teststring, end, "The quick brown fox.* The candlestick", 1);
    wildtest(teststring, end, "T?he quick*", 0);
    wildtest(teststring, end, "T?e quick*", 1);

    printf("---\n");
    printf("Pass: %i\n", pass);
    printf("Fail: %i\n", fail);
    return fail ? 1 : 0;
}

#endif

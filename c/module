/***************************************************************************
 * Function:     Mod_Init
 * Description:  Initialise the module, setting up vectors, callbacks and
 *               any other parts of the system necessary for the module to
 *               function.
 * Parameters:   tail        = pointer to command line (control terminated)
 *               podule_base = address of podule module was started from, or
 *                             NULL if none
 *               pw          = private word for module
 * On exit:      Return NULL for successful initialisation, or a pointer to
 *               an error block if the module could not start properly.
 **************************************************************************/
_kernel_oserror *Mod_Init(const char *tail, int podule_base, void *pw)
{
    _kernel_oserror *err = NULL;
    global_init();
    os_addcallback(StartupCallback_Entry, pw);
    dprintf("MessageTrans initialised\n");
    return err;
}



/***************************************************************************
 * Function:     Mod_Final
 * Description:  Finalise the module, shutting down any systems necessary,
 *               freeing vectors and releasing workspace
 * Parameters:   fatal       = fatality indicator; 1 if fatal, 0 if
 *                             reinitialising
 *               podule_base = address of podule module was started from, or
 *                             NULL if none
 *               pw          = private word for module
 * On exit:      Return 0 for successful finalisation, or a pointer to an
 *               error block if module was not shutdown properly.
 **************************************************************************/
_kernel_oserror *Mod_Final(int fatal, int podule_base, void *pw)
{
    os_removecallback(StartupCallback_Entry, pw);
    gstrans_final();
    descriptor_final();
    dprintf("MessageTrans finalised\n");
    return NULL;
}


/***************************************************************************
 * Function:     StartupCallback_Handler
 * Description:  Generic handler function
 * Parameters:   r  = pointer to register block on entry
 *               pw = private word for module
 * On exit:      Update r to alter return values
 *               Return NULL to return with V clear
 *               Return an error pointer to set V and r0
 **************************************************************************/
_kernel_oserror *StartupCallback_Handler(_kernel_swi_regs *r, void *pw)
{
    os_servicecall2(0, Service_MessageFileClosed);
    return NULL;
}




/***************************************************************************
 * Description:  SWI handler routine for MessageTrans_FileInfo
 * Parameters:   number = SWI number within SWI chunk (i.e. 0 to 63)
 *               r      = pointer to register block on entry
 *               pw     = private word for module
 * On exit:      Return NULL if SWI handled sucessfully, setting return
 *               register values (r0-r9) in r.
 *               Return error_BAD_SWI for out of range SWIs.
 *               Return an error block for a custom error.
 **************************************************************************/
_kernel_oserror *SWI_FileInfo(int number, _kernel_swi_regs *regs, void *pw)
{
    _kernel_oserror *err = NULL;
    /*
     * MessageTrans_FileInfo - Gives information about a message file
     *
     * =>  R1 -> file_name
     * <=  R0 = flags
     *     R2 = size
     */

    /* Input registers */
    const char * file_name = (const char *)regs->r[1];
    /* Output registers */
    MessageTrans_FileFlags flags;
    int32_t size;

    dprintf("MessageTrans_FileInfo %s\n", file_name);

    size = messagefile_size(file_name);
    if (size == -1)
        return err_MessageTransFileOpen;

    /* FIXME: We do not support direct access yet */
    flags = 0;

    regs->r[0] = (int)flags;  // MessageTrans_FileFlags
    regs->r[2] = (int)size;  // .Int
    return err;
}




/***************************************************************************
 * Description:  SWI handler routine for MessageTrans_OpenFile
 * Parameters:   number = SWI number within SWI chunk (i.e. 0 to 63)
 *               r      = pointer to register block on entry
 *               pw     = private word for module
 * On exit:      Return NULL if SWI handled sucessfully, setting return
 *               register values (r0-r9) in r.
 *               Return error_BAD_SWI for out of range SWIs.
 *               Return an error block for a custom error.
 **************************************************************************/
_kernel_oserror *SWI_OpenFile(int number, _kernel_swi_regs *regs, void *pw)
{
    _kernel_oserror *err = NULL;
    /*
     * MessageTrans_OpenFile - Opens a message file
     *
     * =>  R0 = cb
     *     R1 -> file_name
     *     R2 = buffer, or NULL to allocate in the RMA
     */

    /* Input registers */
    MessageTrans_ControlBlock * cb = (MessageTrans_ControlBlock *)regs->r[0];
    char * file_name = (char *)regs->r[1];
    char * buffer = (char *)regs->r[2];
    messagefiledata_t mfd;
    int32_t size;

    dprintf("MessageTrans_OpenFile %s\n", file_name);

    /* Ensure that if we return, the magic is NEVER valid */
    cb->magic = 0;

    /* The API doesn't supply the buffer size, so actually we'll just have
     * to assume that it's correct.
     */
    size = messagefile_size(file_name);
    if (size == -1)
    {
        dprintf("  Failed to open file\n");
        return _kernel_last_oserror();
        //return err_MessageTransFileOpen;
    }
    dprintf("  File size is %i\n", size);

    if (buffer == NULL)
    {
        /* RMA-allocated descriptor, so we need to do special things */
        MessageTrans_ControlBlock * real_cb = descriptor_createproxy();
        mfd.messagefile = (messagefile_t*)malloc(size);
        mfd.size = size;
        if (mfd.messagefile == NULL)
        {
            descriptor_destroy(real_cb);
            return err_NoMemoryLoad;
        }
        err = messagefile_load(file_name, &mfd);
        if (err)
        {
            descriptor_destroy(real_cb);
            free(mfd.messagefile);
            return err;
        }
        err = descriptor_populate(real_cb, &mfd);
        if (err)
        {
            dprintf("  Failed descriptor population: %s\n", err->errmess);
            descriptor_destroy(real_cb);
            free(mfd.messagefile);
            return err;
        }
        err = descriptor_populateproxy(cb, real_cb);
        if (err)
        {
            dprintf("  Failed proxy descriptor population: %s\n", err->errmess);
            descriptor_destroy(real_cb);
            free(mfd.messagefile);
            return err;
        }
    }
    else
    {
        mfd.messagefile = (messagefile_t*)buffer;
        mfd.size = size;
        err = messagefile_load(file_name, &mfd);
        if (err)
        {
            dprintf("  Failed to read in file\n");
            return err;
        }

        err = descriptor_populate(cb, &mfd);
        if (err)
        {
            dprintf("  Failed descriptor population: %s\n", err->errmess);
            return err;
        }
    }
    dprintf("  Opened: magic       = &%08x\n", cb->magic);
    dprintf("          messagefile = %p\n", cb->messagefile);
    dprintf("          size        = &%08x\n", cb->size);

    return err;
}




/***************************************************************************
 * Description:  SWI handler routine for MessageTrans_Lookup
 * Parameters:   number = SWI number within SWI chunk (i.e. 0 to 63)
 *               r      = pointer to register block on entry
 *               pw     = private word for module
 * On exit:      Return NULL if SWI handled sucessfully, setting return
 *               register values (r0-r9) in r.
 *               Return error_BAD_SWI for out of range SWIs.
 *               Return an error block for a custom error.
 **************************************************************************/
_kernel_oserror *SWI_Lookup(int number, _kernel_swi_regs *regs, void *pw)
{
    _kernel_oserror *err = NULL;
    /*
     * MessageTrans_Lookup - Translates a message token into a string
     *
     * =>  R0 -> cb
     *     R1 -> token
     *     R2 = buffer
     *     R3 = size
     *     R4 -> arg0
     *     R5 -> arg1
     *     R6 -> arg2
     *     R7 -> arg3
     * <=  R2 -> result
     *     R3 = used
     */

    /* Input registers */
    MessageTrans_ControlBlock *cb = (MessageTrans_ControlBlock *)regs->r[0];
    const char * token = (const char *)regs->r[1];
    char * buffer = (char *)regs->r[2];
    int32_t size = (int32_t)regs->r[3];
    const char * args[4];
    /* Output registers */
    const char * result;
    int32_t used;
    messagefiledata_t *mfd;
    messagefilefound_t found;

    args[0] = (const char *)regs->r[4];
    args[1] = (const char *)regs->r[5];
    args[2] = (const char *)regs->r[6];
    args[3] = (const char *)regs->r[7];

retry:
    err = descriptor_check(cb, &mfd);
    if (err)
        return err;
    dprintf("MessageTrans_Lookup: cb=%p, token=%s\n", cb, token ? token : "<NULL>");

    found = messagefile_find(mfd, token);
    if (found.value == NULL)
    {
        if (cb != NULL && global_valid())
        {
            cb = NULL;
            goto retry;
        }
        return err_MessageTransTokenNotFound;
    }

    if (buffer == NULL)
    {
        result = found.value;
        used = found.len;
    }
    else
    {
        err = tokens_substitute(&found,
                                buffer,
                                size,
                                args,
                                &used);
        if (err)
            return err;
        result = buffer;
    }

    regs->r[2] = (int)result;  // .String
    regs->r[3] = (int)used - 1;  // .Int
    regs->r[1] = regs->r[2] + regs->r[3];
    return err;
}




/***************************************************************************
 * Description:  SWI handler routine for MessageTrans_MakeMenus
 * Parameters:   number = SWI number within SWI chunk (i.e. 0 to 63)
 *               r      = pointer to register block on entry
 *               pw     = private word for module
 * On exit:      Return NULL if SWI handled sucessfully, setting return
 *               register values (r0-r9) in r.
 *               Return error_BAD_SWI for out of range SWIs.
 *               Return an error block for a custom error.
 **************************************************************************/
_kernel_oserror *SWI_MakeMenus(int number, _kernel_swi_regs *regs, void *pw)
{
    _kernel_oserror *err = NULL;
    /*
     * MessageTrans_MakeMenus - Sets up a menu structure from a definition containing references to tokens
     *
     * =>  R0 -> cb
     *     R1 -> menus
     *     R2 = buffer
     *     R3 = size
     * <=  R3 = remaining (NOTE: oslib says this is the used space)
     */

    /* Input registers */
    MessageTrans_ControlBlock *cb = (MessageTrans_ControlBlock *)regs->r[0];
    const void * menus = (void *)regs->r[1];
    uint8_t * buffer = (uint8_t *)regs->r[2];
    int32_t size = (int32_t)regs->r[3];
    /* Output registers */
    int32_t remaining;
    int32_t required;
    messagefiledata_t *mfd;
    bufferdata_t buf;

    err = descriptor_check(cb, &mfd);
    if (err)
        return err;

    dprintf("MakeMenus: Given %i byte\n", size);

    bufferdata_init(&buf, buffer, size);

    err = menu_writemenus(mfd, menus, &buf);
    if (err)
        return err;

    remaining = bufferdata_remaining(&buf);
    required = bufferdata_required(&buf);

    dprintf("MakeMenus: Required %i bytes, %i remaining, %i given\n", required, remaining, size);
    if (bufferdata_failed(&buf))
        err = err_BufferOverflowMakeMenus;
    else
        remaining = 0; /* The documentation says we return 0 if we were successful */

    regs->r[2] = (int)bufferdata_address(&buf, 0, true); /* End of menu structure */
    regs->r[3] = (int)remaining;  // .Int
    return err;
}





/***************************************************************************
 * Description:  SWI handler routine for MessageTrans_EnumerateTokens
 * Parameters:   number = SWI number within SWI chunk (i.e. 0 to 63)
 *               r      = pointer to register block on entry
 *               pw     = private word for module
 * On exit:      Return NULL if SWI handled sucessfully, setting return
 *               register values (r0-r9) in r.
 *               Return error_BAD_SWI for out of range SWIs.
 *               Return an error block for a custom error.
 **************************************************************************/
_kernel_oserror *SWI_EnumerateTokens(int number, _kernel_swi_regs *regs, void *pw)
{
    _kernel_oserror *err = NULL;
    /*
     * MessageTrans_EnumerateTokens - Enumerates tokens that match a wildcarded token
     *
     * =>  R0 -> cb
     *     R1 -> token
     *     R2 = buffer
     *     R3 = size
     *     R4 = context
     * <=  R2 = more
     *     R3 = used
     *     R4 = context_out
     */

    /* Input registers */
    MessageTrans_ControlBlock *cb = (MessageTrans_ControlBlock *)regs->r[0];
    char * token = (char *)regs->r[1];
    char * buffer = (char *)regs->r[2];
    int32_t size = (int32_t)regs->r[3];
    int32_t context = (int32_t)regs->r[4];
    /* Output registers */
    const char * more;
    int32_t used;
    int32_t context_out;
    messagefiledata_t *mfd;
    messagefilefound_t found;

    err = descriptor_check(cb, &mfd);
    if (err)
        return err;
    dprintf("Enumerate: token=%s, index=%i%s\n", token ? token : "<NULL>", context, buffer==NULL ? " (without copying)" : "");
    found = messagefile_findindex(mfd, token, context);

    if (found.value == NULL)
    {
        more = 0;
        used = 0;
        context_out = 0;
    }
    else
    {
        if (buffer != NULL)
        {
            dprintf("  Copying into buffer %p\n", buffer);
            more = buffer; /* preserved when found */
            if (size < found.len)
            {
                err = err_BufferOverflow;
            }
            else
            {
                memcpy(buffer, found.value, found.len);
                buffer[found.len] = '\0';
            }
        }
        else
        {
            dprintf("  Returning directly as %p\n", found.value);
            /* No copy variant */
            more = found.value;
        }
        used = found.len;
        context_out = context + 1;
    }

    regs->r[2] = (int)more;  // .Bool
    regs->r[3] = (int)used;  // .Int
    regs->r[4] = (int)context_out;  // .Int
    return err;
}




/***************************************************************************
 * Description:  SWI handler routine for MessageTrans_ErrorLookup
 * Parameters:   number = SWI number within SWI chunk (i.e. 0 to 63)
 *               r      = pointer to register block on entry
 *               pw     = private word for module
 * On exit:      Return NULL if SWI handled sucessfully, setting return
 *               register values (r0-r9) in r.
 *               Return error_BAD_SWI for out of range SWIs.
 *               Return an error block for a custom error.
 **************************************************************************/
_kernel_oserror *SWI_ErrorLookup(int number, _kernel_swi_regs *regs, void *pw)
{
    _kernel_oserror *err = NULL;
    /*
     * MessageTrans_ErrorLookup - Translates a message token within an error block
     *
     * =>  R0 -> error
     *     R1 -> cb
     *     R2 = buffer
     *     R3 = size
     *     R4 -> arg0
     *     R5 -> arg1
     *     R6 -> arg2
     *     R7 -> arg3
     */

    /* Input registers */
    _kernel_oserror *error = (_kernel_oserror *)regs->r[0];
    MessageTrans_ControlBlock *cb = (MessageTrans_ControlBlock *)regs->r[1];
    _kernel_oserror * out_error = (_kernel_oserror *)regs->r[2];
    int32_t size = (int32_t)regs->r[3];
    const char * args[4];
    messagefiledata_t *mfd;
    messagefilefound_t found;

    args[0] = (const char *)regs->r[4];
    args[1] = (const char *)regs->r[5];
    args[2] = (const char *)regs->r[6];
    args[3] = (const char *)regs->r[7];

retry:
    err = descriptor_check(cb, &mfd);
    if (err)
        return err;
    found = messagefile_find(mfd, error->errmess);
    if (found.value == NULL)
    {
        if (cb != NULL && global_valid())
        {
            cb = NULL;
            goto retry;
        }
        return err_MessageTransTokenNotFound;
    }

    if (out_error == NULL)
    {
        /* Get buffer */
        out_error = errorbufs_allocate();
    }

    {
        char *buffer = out_error->errmess;
        out_error->errnum = error->errnum;
        err = tokens_substitute(&found,
                                buffer,
                                size - 4,
                                args,
                                NULL);
        if (err)
            return err;
        err = out_error;
    }

    return err;
}




/***************************************************************************
 * Description:  SWI handler routine for MessageTrans_GSLookup
 * Parameters:   number = SWI number within SWI chunk (i.e. 0 to 63)
 *               r      = pointer to register block on entry
 *               pw     = private word for module
 * On exit:      Return NULL if SWI handled sucessfully, setting return
 *               register values (r0-r9) in r.
 *               Return error_BAD_SWI for out of range SWIs.
 *               Return an error block for a custom error.
 **************************************************************************/
_kernel_oserror *SWI_GSLookup(int number, _kernel_swi_regs *regs, void *pw)
{
    _kernel_oserror *err = NULL;
    /*
     * MessageTrans_GSLookup - Translates a message token into a string and calls OS_GSTrans
     *
     * =>  R0 -> cb
     *     R1 -> token
     *     R2 = buffer
     *     R3 = size
     *     R4 -> arg0
     *     R5 -> arg1
     *     R6 -> arg2
     *     R7 -> arg3
     * <=  R2 -> result
     *     R3 = used
     */

    /* Input registers */
    MessageTrans_ControlBlock *cb = (MessageTrans_ControlBlock *)regs->r[0];
    const char * token = (const char *)regs->r[1];
    char * buffer = (char *)regs->r[2];
    int32_t size = (int32_t)regs->r[3];
    const char * args[4];
    /* Output registers */
    const char * result;
    int32_t used;
    messagefiledata_t *mfd;
    messagefilefound_t found;

    args[0] = (const char *)regs->r[4];
    args[1] = (const char *)regs->r[5];
    args[2] = (const char *)regs->r[6];
    args[3] = (const char *)regs->r[7];

retry:
    err = descriptor_check(cb, &mfd);
    if (err)
        return err;
    found = messagefile_find(mfd, token);
    if (found.value == NULL)
    {
        if (cb != NULL && global_valid())
        {
            cb = NULL;
            goto retry;
        }
        return err_MessageTransTokenNotFound;
    }

    if (buffer == NULL)
    {
        /* No GSTrans performed - we just return the pointer to the found value */
        result = found.value;
        used = found.len;
    }
    else
    {
        int new_size;
        char *new_buffer = gstrans_getbuffer(size, &new_size);
        if (new_buffer == NULL)
            return err_NoMemoryGS;
        err = tokens_substitute(&found,
                                new_buffer,
                                new_size,
                                args,
                                &used);
        if (err)
        {
            if (err->errnum == ErrorNumber_BuffOverflow)
            {
                /* It failed with the buffer size given, so try with new size */
                /* Probably the main way this would fail would be if the size
                 * of the system variables that were substituted was massively
                 * longer than their substitution.
                 */
                new_buffer = gstrans_getbuffer(used, &new_size);
                if (new_buffer == NULL)
                    return err_NoMemoryGS;
                err = tokens_substitute(&found,
                                        new_buffer,
                                        new_size,
                                        args,
                                        &used);
                if (err)
                {
                    /* If we got an error at this point we're almost certainly
                     * stuffed.
                     */
                    return err;
                }
            }
        }

        /* new_buffer now has information we want to GSTrans */
        err = gstrans_translate(new_buffer, buffer, size, &used);
        if (err)
            return err;
        result = buffer;
    }


    regs->r[2] = (int)result;  // .String
    regs->r[3] = (int)used;  // .Int
    return err;
}




/***************************************************************************

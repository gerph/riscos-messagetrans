/*************************************************** Gerph *********
 Function:      global_init
 Description:   Initialise the Global messages descriptor
 Parameters:    none
 Returns:       none
 ******************************************************************/
void global_init(void)
{
    _kernel_oserror *err;
    uint32_t size = strlen(globalmessages);
    messagefiledata_t mfd;

    mfd.messagefile = (messagefile_t *)globalmessages;
    mfd.size = size;

    initialised = false;
    err = descriptor_populate(&global_cb, &mfd);
    if (err)
        initialised = false;
    else
        initialised = true;
}

/*************************************************** Gerph *********
 Function:      global_getcb
 Description:   Read the global control block
 Parameters:    none
 Returns:       pointer to the global control block (or NULL if none available)
 ******************************************************************/
MessageTrans_ControlBlock *global_getcb(void)
{
    if (initialised)
        return &global_cb;
    else
        return NULL;
}

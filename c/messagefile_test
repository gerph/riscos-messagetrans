/*******************************************************************
 * File:        messagefile_test
 * Purpose:     Test that the MessageFile token processing works
 * Author:      Gerph
 * Date:        17 Jul 2025
 ******************************************************************/

#include <stdlib.h>
#include <stdio.h>
#include <string.h>

#include "messagefile.h"


int main(int argc, char *argv[])
{
    _kernel_oserror *err;
    messagefiledata_t mfd;
    int32_t size;
    char *filename;

    if (argc < 2)
    {
        printf("Syntax: MessageFileTest <filename> [<token>*]\n");
        exit(1);
    }
    filename = argv[1];

    size = messagefile_size(filename);
    if (size == -1)
    {
        printf("Failed to read file\n");
        exit(1);
    }

    mfd.size = size;
    mfd.messagefile = malloc(size);
    if (mfd.messagefile == NULL)
    {
        printf("Failed to allocate space for file\n");
        exit(1);
    }

    err = messagefile_load(filename, &mfd);
    if (err)
    {
        printf("Failed to load: %s\n", err->errmess);
        exit(1);
    }

    if (argc > 2 && strchr(argv[2], '*') == NULL && strchr(argv[2], '?') == NULL)
    {
        /* Find explicit tokens */
        int i;
        for (i = 2; i < argc; i++)
        {
            messagefilefound_t found;
            printf("Find token: '%s': ", argv[i]);
            found = messagefile_find(&mfd, argv[i]);
            if (found.value == NULL)
            {
                printf("<NULL>\n");
            }
            else
            {
                printf("'%.*s'\n", found.len, found.value);
            }
        }
    }
    else
    {
        /* Enumerate tokens */
        const char *wild = argc > 2 ? argv[2] : NULL;
        int i;
        printf("Enumerating with wildcard %s\n", wild ? wild : "<NULL>");
        for (i = 0; ; i++)
        {
            messagefilefound_t found;
            printf("Enumerate tokens: #%i: ", i);
            found = messagefile_findindex(&mfd, wild, i);
            if (found.value == NULL)
            {
                printf("<NULL>\n");
                break;
            }
            else
            {
                printf("'%.*s'\n", found.len, found.value);
            }
        }

    }
    return 0;
}

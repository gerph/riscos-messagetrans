#include <stdlib.h>
#include <stdint.h>

#include "kernel.h"

#include "modhead.h"
#include "messagefile.h"
#include "tokens.h"

/* Configuration option for whether we error on the overflow of strings */
/* RISC OS Classic does not error if we cannot fit the string in, it
   insead truncates the string. */
//#define ERROR_ON_OVERFLOW


/*************************************************** Gerph *********
 Function:      tokens_substitute
 Description:   Perform substitution of the %0-3 values in the message
 Parameters:    found-> the token string to expand
                buffer-> the buffer to populate
                size = the size of the buffer
                args-> the args to use
                usedp-> where to store the length written
 Returns:       pointer to an error, or NULL if ok
 ******************************************************************/
_kernel_oserror *tokens_substitute(messagefilefound_t *found,
                                   char *buffer,
                                   int32_t size,
                                   const char **args,
                                   int32_t *usedp)
{
#define ACCUMULATE(c) do { if (out < end) *out++ = (c); else out++; } while (0)
    const char *msg = found->value;
    char *out = buffer;
    int len = found->len;
    char *end = buffer + size;
    int i;

    for (i=0; i<len; i++)
    {
        char c = msg[i];
        if (c == '%')
        {
            i++;
            c = msg[i];
            if (c == '\0')
            {
                ACCUMULATE('%');
            }
            else if (c == '0' || c == '1' || c == '2' || c == '3')
            {
                /* Expand */
                int n = c - '0';
                const char *arg = args[n];
                if (arg < (const char *)0x8000)
                {
                    ACCUMULATE('%');
                    ACCUMULATE(c);
                }
                else
                {
                    /* We can actually expand to the argument */
                    while (*arg != '\0' && *arg != '\n' && *arg != '\r')
                    {
                        ACCUMULATE(*arg);
                        arg++;
                    }
                }
            }
            else
            {
                ACCUMULATE('%');
                ACCUMULATE(c);
            }
        }
        else
        {
            ACCUMULATE(c);
        }
    }
    ACCUMULATE('\0');
    /* Always populate the buffer with the space it would have used */
    if (usedp)
        *usedp = (out - buffer);
    if (out <= end)
    {
        /* It fit into their buffer, so we can return success */
        return NULL;
    }
#ifdef ERROR_ON_OVERFLOW
    return err_BufferOverflow;
#else
    /* Truncate the string rather than error */
    if (usedp)
        *usedp = size;
    buffer[size - 1] = '\0';
    return NULL;
#endif
}
